{
  "name": "hackerrank-for-work-cli",
  "version": "0.1.0",
  "description": "CLI to fetch interview and test results from HackerRank for Work",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "hackerrank": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
